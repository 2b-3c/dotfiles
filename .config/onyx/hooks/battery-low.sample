#!/bin/bash
# Hook: called when battery reaches critical level.
# Argument $1 = current battery percentage.
# To activate: remove .sample from filename.

SOUND_FILE="/usr/share/sounds/freedesktop/stereo/dialog-warning.oga"
if command -v mpv &>/dev/null && [[ -f "$SOUND_FILE" ]]; then
  mpv --no-video "$SOUND_FILE" >/dev/null 2>&1
fi
