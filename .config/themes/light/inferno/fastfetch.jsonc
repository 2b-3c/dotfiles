{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "logo": {
    "type": "file",
    "source": "~/.config/fastfetch/onyx.txt",
    "color": { "1": "red" },
    "padding": {
      "top": 2,
      "right": 6,
      "left": 2
    }
  },
  "display": {
    "separator": " "
  },
  "modules": [
    "break",
    {
      "type": "custom",
      "key": "{#7} HARDWARE INFORMATION {#}{#31}\uE0B0",
      "keyColor": "red"
    },
    { "type": "host",    "key": "├─ PC  ", "keyColor": "red" },
    { "type": "cpu",     "key": "├─ CPU ", "showPeCoreCount": true, "keyColor": "red" },
    { "type": "gpu",     "key": "├─ GPU ", "detectionMethod": "pci", "keyColor": "red" },
    { "type": "display", "key": "├─ RES ", "keyColor": "red", "compactType": "original" },
    { "type": "disk",    "key": "├─ DSK ", "keyColor": "red" },
    { "type": "memory",  "key": "├─ RAM ", "keyColor": "red" },
    { "type": "swap",    "key": "└─ SWP ", "keyColor": "red" },
    "break",
    {
      "type": "custom",
      "key": "{#7} SOFTWARE INFORMATION {#}{#31}\uE0B0",
      "keyColor": "red"
    },
    { "type": "command",      "key": "├─ OS  ", "keyColor": "red", "text": "bash ~/.config/fastfetch/scripts/version.sh" },
    { "type": "command",      "key": "├─ BR  ", "keyColor": "red", "text": "bash ~/.config/fastfetch/scripts/version-branch.sh" },
    { "type": "command",      "key": "├─ CH  ", "keyColor": "red", "text": "bash ~/.config/fastfetch/scripts/version-channel.sh" },
    { "type": "kernel",       "key": "├─ KER ", "keyColor": "red" },
    { "type": "wm",           "key": "├─ WM  ", "keyColor": "red" },
    { "type": "terminal",     "key": "├─ TER ", "keyColor": "red" },
    { "type": "packages",     "key": "├─ PKG ", "keyColor": "red" },
    { "type": "command",      "key": "├─ CLR ", "keyColor": "red", "text": "bash ~/.config/fastfetch/scripts/theme-current.sh" },
    { "type": "terminalfont", "key": "└─ FNT ", "keyColor": "red" },
    "break",
    {
      "type": "custom",
      "key": "{#7} AGE / UPTIME / UPDATE {#}{#31}\uE0B0",
      "keyColor": "red"
    },
    { "type": "command", "key": "├─ AGE ", "keyColor": "red", "text": "echo $(( ($(date +%s) - $(stat -c %W /)) / 86400 )) days" },
    { "type": "uptime",  "key": "├─ UPT ", "keyColor": "red" },
    { "type": "command", "key": "└─ UPD ", "keyColor": "red", "text": "bash ~/.config/fastfetch/scripts/version-pkgs.sh" },
    "break",
    { "type": "colors", "symbol": "squares", "paddingLeft": 1 }
  ]
}
